# ─── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="LG Dashboard"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── AI / Gemini ─────────────────────────────────────
# Lấy tại: https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=""
NEXT_PUBLIC_GEMINI_MODEL="gemini-1.5-pro"
NEXT_PUBLIC_GEMINI_FLASH_MODEL="gemini-1.5-flash"
NEXT_PUBLIC_OCR_ENGINE="gemini"
NEXT_PUBLIC_OCR_MAX_RETRIES="3"
NEXT_PUBLIC_OCR_TIMEOUT_MS="60000"

# ─── Google Apps Script ──────────────────────────────
NEXT_PUBLIC_GAS_WEB_APP_URL=""
NEXT_PUBLIC_GAS_API_SECRET=""

# ─── Google Drive Folder IDs ─────────────────────────
NEXT_PUBLIC_GOOGLE_DRIVE_PDF_FOLDER_ID=""
NEXT_PUBLIC_GOOGLE_DRIVE_EXCEL_FOLDER_ID=""
NEXT_PUBLIC_GOOGLE_DRIVE_DETAIL_FOLDER_ID=""

# ─── Google Sheets ────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SHEETS_SPREADSHEET_ID=""
NEXT_PUBLIC_GOOGLE_SHEETS_INVOICE_SHEET="INVOICES"
NEXT_PUBLIC_GOOGLE_SHEETS_VERSION_SHEET="VERSIONS"
