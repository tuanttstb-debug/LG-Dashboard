# ─── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="LG Dashboard"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── AI / Gemini ─────────────────────────────────────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"
GEMINI_FLASH_MODEL="gemini-1.5-flash"

# OCR engine: "gemini" | "tesseract"
OCR_ENGINE="gemini"
OCR_MAX_RETRIES="3"
OCR_TIMEOUT_MS="60000"

# ─── Google Apps Script ──────────────────────────────
GAS_WEB_APP_URL=""
GAS_API_SECRET=""

# ─── Google Drive Folder IDs ─────────────────────────
GOOGLE_DRIVE_PDF_FOLDER_ID=""
GOOGLE_DRIVE_EXCEL_FOLDER_ID=""
GOOGLE_DRIVE_DETAIL_FOLDER_ID=""

# ─── Google Sheets ────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_INVOICE_SHEET="INVOICES"
GOOGLE_SHEETS_VERSION_SHEET="VERSIONS"
GOOGLE_SHEETS_METADATA_SHEET="METADATA"

# ─── Courier ─────────────────────────────────────────
DEFAULT_COURIER="fedex"
