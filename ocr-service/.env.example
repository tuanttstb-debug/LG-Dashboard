# Tesseract binary path (Windows)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Tessdata dir — absolute path to the tessdata folder
TESSDATA_PREFIX=D:\Workspace\Production\LG Dashboard\ocr-service\tessdata

# Default OCR language(s). Use + to combine: vie+eng
DEFAULT_LANG=vie+eng

# Max upload size in MB
MAX_FILE_SIZE_MB=20

# Shared secret — callers must send this in X-API-Secret header
API_SECRET=change-me-in-production

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3000,https://tuanttstb-debug.github.io
